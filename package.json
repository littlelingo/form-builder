{
  "name": "va-form-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone authoring schema, compiler, and audit foundation for low-code VA.gov form generation.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "compile:example": "node src/cli/compile.mjs examples/21-4140-authoring.json",
    "compile:example:27-8832": "node src/cli/compile.mjs examples/27-8832-authoring.json",
    "builder:dev": "npm --workspace @va/form-builder-ui run dev",
    "builder:build": "npm --workspace @va/form-builder-ui run build",
    "builder:smoke": "node tests/builder-smoke.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
