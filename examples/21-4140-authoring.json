{
  "schemaVersion": "1.0.0",
  "formDefinitionVersion": 1,
  "formId": "21-4140",
  "title": "Employment Questionnaire",
  "plainLanguageHeader": "Tell us about your employment history",
  "subTitle": "VA Form 21-4140",
  "rootUrl": "/employment-questionnaire-form-21-4140",
  "trackingPrefix": "21-4140-eq-",
  "submitUrl": "/v0/form-21-4140",
  "version": 0,
  "componentSystems": {
    "primary": "uswds",
    "generated": "vaFormsSystem",
    "preview": "uswds",
    "additional": ["shadcn"]
  },
  "prefill": {
    "enabled": true,
    "mappings": [
      { "source": "profile.email", "target": "email" },
      { "source": "profile.phone", "target": "phone" }
    ]
  },
  "computedValues": [
    {
      "id": "contactSummary",
      "target": "metadata.contactSummary",
      "operation": "concat",
      "sources": ["email", "phone"],
      "separator": " | "
    }
  ],
  "chapters": [
    {
      "id": "contactInformation",
      "type": "standard",
      "title": "Contact information",
      "pages": [
        {
          "id": "contactInformationPage",
          "title": "Your contact information",
          "bodyText": "We will use this information if we need to contact you about your employment questionnaire.",
          "components": [
            {
              "id": "email",
              "type": "email",
              "label": "Email address",
              "required": true,
              "autocomplete": "email"
            },
            {
              "id": "phone",
              "type": "phone",
              "label": "Phone number",
              "required": true,
              "autocomplete": "tel"
            }
          ]
        }
      ]
    },
    {
      "id": "supportingEvidence",
      "type": "standard",
      "title": "Supporting evidence",
      "pages": [
        {
          "id": "evidenceUpload",
          "title": "Upload supporting evidence",
          "bodyText": "You can upload documents that show employment changes, income changes, or other relevant details.",
          "components": [
            {
              "id": "hasEvidence",
              "type": "yesNo",
              "label": "Do you want to upload supporting evidence?",
              "required": true
            },
            {
              "id": "supportingFiles",
              "type": "fileUpload",
              "label": "Upload supporting documents",
              "hint": "Upload PDF, JPG, or PNG files.",
              "showIf": {
                "field": "hasEvidence",
                "operator": "equals",
                "value": true
              },
              "requiredIf": {
                "field": "hasEvidence",
                "operator": "equals",
                "value": true
              },
              "multiple": true,
              "accept": [".pdf", ".jpg", ".jpeg", ".png"],
              "maxFileSize": 10485760,
              "maxFileCount": 5,
              "endpoint": "/v0/form-21-4140/attachments",
              "disallowEncryptedPdfs": true
            }
          ]
        }
      ]
    },
    {
      "id": "employmentHistory",
      "type": "listLoop",
      "title": "Employment history",
      "sectionIntro": "Add each employer or self-employment period we should review.",
      "itemNameLabel": "Employer or business name",
      "options": {
        "nounSingular": "employer",
        "nounPlural": "employers",
        "arrayPath": "employmentHistory",
        "required": true,
        "maxItems": 10
      },
      "pages": [
        {
          "id": "employerDetails",
          "title": "Employer details",
          "components": [
            {
              "id": "employerName",
              "type": "textInput",
              "label": "Employer or business name",
              "required": true,
              "summaryCard": true,
              "maxLength": 80
            },
            {
              "id": "employmentType",
              "type": "select",
              "label": "Type of work",
              "required": true,
              "responseOptions": [
                { "value": "fullTime", "label": "Full-time employment" },
                { "value": "partTime", "label": "Part-time employment" },
                { "value": "selfEmployment", "label": "Self-employment" },
                { "value": "other", "label": "Other" }
              ]
            },
            {
              "id": "monthlyIncome",
              "type": "textInput",
              "label": "Average monthly income",
              "hint": "Enter dollars only.",
              "inputType": "number",
              "required": true,
              "validations": [
                {
                  "message": "Monthly income must be zero or more.",
                  "rule": {
                    "field": "$field",
                    "operator": "greaterThanOrEqual",
                    "value": 0
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "employmentDates",
          "title": "Employment dates",
          "components": [
            {
              "id": "startDate",
              "type": "date",
              "label": "Start date",
              "required": true
            },
            {
              "id": "endDate",
              "type": "date",
              "label": "End date",
              "hint": "Leave blank if this job is current."
            },
            {
              "id": "reasonEnded",
              "type": "textArea",
              "label": "Tell us why this job ended",
              "showIf": {
                "field": "endDate",
                "operator": "exists"
              },
              "maxLength": 500
            }
          ]
        }
      ]
    }
  ]
}
