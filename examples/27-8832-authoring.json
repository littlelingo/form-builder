    {
      "id": "remarks",
      "type": "standard",
      "title": "Remarks",
      "pages": [
        {
          "id": "remarksPage",
          "title": "Remarks",
          "bodyText": "Use this space to provide information that does not fit elsewhere on this form or that will help VA process your claim. Refer to item numbers when possible.",
          "components": [
            {
              "id": "remarks",
              "type": "textArea",
              "label": "Remarks",
              "maxLength": 3000
            }
          ]
        }
      ]
    },
    {
      "id": "certification",
      "type": "standard",
      "title": "Certification and signature",
      "pages": [
        {
          "id": "certificationPage",
          "title": "Certification",
          "bodyText": "The paper form requires a wet signature. In this builder example, the signature is represented as a certification checkbox plus typed name and date fields. Production deployment must confirm digital signature and submission requirements.",
          "components": [
            {
              "id": "certificationStatement",
              "type": "checkbox",
              "label": "Certification",
              "required": true,
              "responseOptions": [
                {
                  "value": "certified",
                  "label": "I certify that I have completed this statement and that its information is true and correct to the best of my knowledge and belief."
                }
              ]
            },
            {
              "id": "applicantSignatureName",
              "type": "textInput",
              "label": "Veteran, service member, or claimant typed signature",
              "required": true,
              "maxLength": 80
            },
            {
              "id": "applicantSignatureDate",
              "type": "date",
              "label": "Date signed",
              "required": true
            },
            {
              "id": "hasAlternateSigner",
              "type": "yesNo",
              "label": "Will a parent, guardian, or custodian sign for the applicant?",
              "required": true
            }
          ]
        },
        {
          "id": "alternateSignerPage",
          "title": "Parent, guardian, or custodian signature",
          "bodyText": "Complete this section only when a parent, guardian, or custodian signs for the applicant.",
          "condition": {
            "field": "hasAlternateSigner",
            "operator": "equals",
            "value": true
          },
          "components": [
            {
              "id": "alternateSignerType",
              "type": "radioButton",
              "label": "Alternate signer relationship",
              "required": true,
              "responseOptions": [
                { "value": "parent", "label": "Parent" },
                { "value": "guardian", "label": "Guardian" },
                { "value": "custodian", "label": "Custodian" }
              ]
            },
            {
              "id": "alternateSignerName",
              "type": "textInput",
              "label": "Parent, guardian, or custodian typed signature",
              "required": true,
              "maxLength": 80
            },
            {
              "id": "alternateSignerDate",
              "type": "date",
              "label": "Date signed",
              "required": true
            },
            {
              "id": "alternateSignerPhone",
