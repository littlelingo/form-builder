      "condition": {
        "field": "applicantType",
        "operator": "equals",
        "value": "dependentClaimant"
      },
      "pages": [
        {
          "id": "claimantIdentityPage",
          "title": "Claimant identification information",
          "bodyText": "Complete this section only if the claimant is not the Veteran.",
          "components": [
            {
              "id": "claimantFullName",
              "type": "textInput",
              "label": "Claimant's full name",
              "hint": "First, middle initial, and last name",
              "required": true,
              "autocomplete": "name",
              "maxLength": 80
            },
            {
              "id": "claimantSsn",
              "type": "textInput",
              "label": "Claimant's Social Security number",
              "hint": "Production hardening gap: use a masked SSN control before deployment.",
              "required": true,
              "inputType": "text",
              "pattern": "^[0-9]{9}$",
              "maxLength": 9
            },
            {
              "id": "claimantDateOfBirth",
              "type": "date",
              "label": "Claimant's date of birth",
              "required": true
            },
            {
              "id": "claimantVaFileNumber",
              "type": "textInput",
              "label": "Claimant VA file number",
              "hint": "If applicable",
              "pattern": "^[0-9]{8}$",
              "maxLength": 8
            },
            {
              "id": "claimantRelationship",
              "type": "radioButton",
              "label": "Relationship to Veteran",
              "hint": "Child includes biological children, adopted children, stepchildren, or married children with transferred entitlement and education benefits remaining.",
              "required": true,
              "responseOptions": [
                { "value": "spouse", "label": "Spouse" },
                { "value": "child", "label": "Child" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "claimantContact",
      "type": "standard",
      "title": "Claimant contact information",
      "condition": {
        "field": "applicantType",
        "operator": "equals",
        "value": "dependentClaimant"
      },
      "pages": [
        {
          "id": "claimantContactPage",
          "title": "Claimant contact information",
          "components": [
            {
              "id": "claimantMailingAddress",
              "type": "address",
