  "computedValues": [],
  "chapters": [
    {
      "id": "introductionAndEligibility",
      "type": "standard",
      "title": "Introduction and eligibility",
      "pages": [
        {
          "id": "eligibilitySummary",
          "title": "Personalized career planning and guidance",
          "bodyText": "Use this form to apply for Personalized Career Planning and Guidance benefits under 38 U.S.C. Chapter 36. You may be eligible if you are a Veteran with an education benefit, recently discharged under conditions other than dishonorable, on active duty with 6 months or less before release or discharge, or an eligible dependent with transferred Post-9/11 GI Bill benefits.",
          "components": [
            {
              "id": "guidanceInterests",
              "type": "checkbox",
              "label": "What type of guidance are you interested in?",
              "hint": "Select all that apply. This helps VA understand the services that may support your planning.",
              "responseOptions": [
                {
                  "value": "educationCareerAssessment",
                  "label": "Education and career assessment services"
                },
                {
                  "value": "employmentServices",
                  "label": "Employment services"
                },
                {
                  "value": "educationalServices",
                  "label": "Educational services"
                },
                {
                  "value": "counselingServices",
                  "label": "Counseling services"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "applicantType",
      "type": "standard",
      "title": "Applicant type",
      "pages": [
        {
          "id": "applicantTypePage",
          "title": "Tell us who is applying",
          "bodyText": "The Veteran or service member information is required for every application. Complete claimant information only when the claimant is not the Veteran or service member.",
          "components": [
            {
              "id": "applicantType",
              "type": "radioButton",
              "label": "Who is applying for this benefit?",
              "required": true,
              "responseOptions": [
                {
                  "value": "veteranOrServiceMember",
                  "label": "Veteran or service member"
                },
                {
                  "value": "dependentClaimant",
                  "label": "Dependent claimant"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "veteranIdentity",
      "type": "standard",
      "title": "Veteran or service member identity",
      "pages": [
        {
          "id": "veteranIdentityPage",
          "title": "Veteran or service member information",
          "bodyText": "Enter the Veteran or service member's identifying information.",
          "components": [
            {
              "id": "veteranFullName",
              "type": "textInput",
              "label": "Veteran or service member's full name",
              "hint": "First, middle, and last name",
              "required": true,
              "autocomplete": "name",
              "maxLength": 80
            },
            {
              "id": "veteranSsn",
              "type": "textInput",
              "label": "Veteran or service member's Social Security number",
              "hint": "Production hardening gap: use a masked SSN control before deployment.",
              "required": true,
              "inputType": "text",
              "pattern": "^[0-9]{9}$",
              "maxLength": 9
            },
            {
              "id": "veteranDateOfBirth",
              "type": "date",
              "label": "Veteran or service member's date of birth",
              "required": true
            },
            {
              "id": "veteranVaFileNumber",
              "type": "textInput",
              "label": "VA file number",
              "hint": "If VA assigned an 8 digit file number, enter it here. Production hardening gap: use masking or stricter formatting before deployment.",
              "pattern": "^[0-9]{8}$",
              "maxLength": 8
            }
          ]
        }
      ]
    },
    {
      "id": "veteranContact",
      "type": "standard",
      "title": "Veteran or service member contact information",
      "pages": [
        {
          "id": "veteranContactPage",
          "title": "Veteran or service member contact information",
          "bodyText": "VA will use this information to contact the Veteran or service member about this application.",
          "components": [
            {
              "id": "veteranMailingAddress",
              "type": "address",
              "label": "Veteran or service member's mailing address",
              "required": true,
              "militaryAddress": true
            },
            {
              "id": "veteranPhone",
              "type": "phone",
              "label": "Veteran or service member's phone number",
              "required": true,
              "autocomplete": "tel"
            },
            {
              "id": "veteranEmail",
              "type": "email",
              "label": "Veteran or service member's email address",
              "required": true,
              "autocomplete": "email"
            },
            {
              "id": "veteranElectronicCorrespondence",
              "type": "checkbox",
              "label": "Electronic correspondence",
              "responseOptions": [
                {
                  "value": "agrees",
                  "label": "I agree to receive electronic correspondence from VA about this claim."
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "schoolTraining",
      "type": "standard",
      "title": "School or training attendance",
      "pages": [
        {
          "id": "veteranSchoolTrainingPage",
          "title": "Veteran or service member school or training",
          "components": [
            {
              "id": "veteranAttendingSchool",
              "type": "yesNo",
              "label": "Are you currently attending a school or training facility?",
              "required": true
            },
            {
              "id": "veteranSchoolName",
              "type": "textInput",
              "label": "Name of school or training facility",
              "requiredIf": {
                "field": "veteranAttendingSchool",
                "operator": "equals",
                "value": true
              },
              "showIf": {
                "field": "veteranAttendingSchool",
                "operator": "equals",
                "value": true
              },
              "maxLength": 80
            }
          ]
        }
      ]
    },
    {
      "id": "militaryService",
      "type": "standard",
      "title": "Military service",
      "pages": [
        {
          "id": "militaryServiceDatesPage",
          "title": "Military service dates",
          "bodyText": "Enter the most recent period of active duty service. Add additional service dates in remarks.",
          "components": [
            {
              "id": "activeDutyEnteredDate",
              "type": "date",
              "label": "Date entered active duty",
              "required": true
            },
            {
              "id": "activeDutySeparatedDate",
              "type": "date",
              "label": "Date separated from active duty or projected separation date",
              "hint": "Production hardening gap: projected separation dates may need future-date support in generated VA output.",
              "required": true
            }
          ]
        },
        {
          "id": "militaryServiceDetailsPage",
          "title": "Military service details",
          "components": [
            {
              "id": "branchOfService",
              "type": "radioButton",
              "label": "Branch of service",
              "required": true,
              "responseOptions": [
                { "value": "army", "label": "Army" },
                { "value": "navy", "label": "Navy" },
                { "value": "marineCorps", "label": "Marine Corps" },
                { "value": "airForce", "label": "Air Force" },
                { "value": "coastGuard", "label": "Coast Guard" },
                { "value": "spaceForce", "label": "Space Force" },
                { "value": "noaa", "label": "NOAA" },
                { "value": "usphs", "label": "USPHS" }
              ]
            },
            {
              "id": "serviceComponent",
              "type": "radioButton",
              "label": "Component",
              "required": true,
              "responseOptions": [
                { "value": "active", "label": "Active" },
                { "value": "reserves", "label": "Reserves" },
                { "value": "nationalGuard", "label": "National Guard" }
              ]
            },
            {
              "id": "characterOfDischarge",
              "type": "radioButton",
              "label": "Character of discharge",
              "required": true,
              "responseOptions": [
                { "value": "honorable", "label": "Honorable" },
                { "value": "otherThanHonorable", "label": "Other than honorable" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "claimantIdentity",
      "type": "standard",
