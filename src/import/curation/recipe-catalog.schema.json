{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://va.gov/form-builder/import/recipe-catalog.schema.json",
  "title": "PDF Import Curation Recipe Catalog",
  "type": "object",
  "required": ["version", "recipes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string" },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe" }
    }
  },
  "$defs": {
    "recipe": {
      "type": "object",
      "required": ["id", "match", "fields"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "formFingerprint": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "match": { "$ref": "#/$defs/match" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fieldMapping" }
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allText": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "anyText": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fieldNamePatterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "minFieldMatches": { "type": "number", "minimum": 0 }
      }
    },
    "fieldMapping": {
      "type": "object",
      "required": ["selector", "chapterId", "pageId"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "selector": { "$ref": "#/$defs/selector" },
        "chapterId": { "type": "string", "minLength": 1 },
        "chapterTitle": { "type": "string" },
        "pageId": { "type": "string", "minLength": 1 },
        "pageTitle": { "type": "string" },
        "component": { "$ref": "#/$defs/componentOverrides" }
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namePattern": { "type": "string", "minLength": 1 },
        "labelPattern": { "type": "string", "minLength": 1 },
        "textPattern": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["namePattern"] },
        { "required": ["labelPattern"] },
        { "required": ["textPattern"] }
      ]
    },
    "componentOverrides": {
      "type": "object",
      "additionalProperties": true,
      "not": {
        "anyOf": [
          { "required": ["id"] },
          { "required": ["provenance"] }
        ]
      }
    }
  }
}
